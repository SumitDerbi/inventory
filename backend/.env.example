# Inventory BPA — Backend env template
# Copy to `.env` for local dev. Production reads `inventory.env` per stack.md.

DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=django-insecure-change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# sqlite for local dev (default), mysql for production:
# DATABASE_URL=mysql://user:pass@127.0.0.1:3306/inventory
DATABASE_URL=sqlite:///db.sqlite3

# CORS — Vite dev origin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
