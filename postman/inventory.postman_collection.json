          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/customers/", "host": ["{{base_url}}"], "path": ["api", "v1", "customers", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_type\": \"company\",\n  \"company_name\": \"{{q_unique_company}}\",\n  \"contact_person_name\": \"Quinn\",\n  \"mobile\": \"{{q_unique_mobile}}\",\n  \"email\": \"{{q_unique_email}}\"\n}"
            }
          }
        },
