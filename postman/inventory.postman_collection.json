        },
        {
          "name": "Create Customer (Quote)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = String(Date.now());",
                  "pm.variables.set('q_unique_mobile', '8' + ts.slice(-9));",
                  "pm.variables.set('q_unique_email', 'qpat' + ts + '@example.com');",
                  "pm.variables.set('q_unique_company', 'QPostman Co ' + ts);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 created', () => pm.response.to.have.status(201));",
