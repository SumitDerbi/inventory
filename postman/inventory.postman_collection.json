            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/tax-rules/", "host": ["{{base_url}}"], "path": ["api", "v1", "tax-rules", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"GST 18 PM {{$timestamp}}\",\n  \"tax_type\": \"GST\",\n  \"rate_percent\": \"18.00\",\n  \"applicable_to\": \"product\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
