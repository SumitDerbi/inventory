              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const today = new Date();",
                  "const fmt = (d) => d.toISOString().slice(0, 10);",
                  "pm.variables.set('q_today', fmt(today));",
                  "const exp = new Date(today.getTime() + 30*24*60*60*1000);",
                  "pm.variables.set('q_valid_until', fmt(exp));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 created', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.expect(j.quotation_number).to.match(/^QUO/);",
                  "pm.expect(j.status).to.eql('draft');",
                  "pm.environment.set('quotation_id', j.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/quotations/", "host": ["{{base_url}}"], "path": ["api", "v1", "quotations", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"customer\": {{q_customer_id}},\n  \"project_name\": \"Postman Quote\",\n  \"quotation_date\": \"{{q_today}}\",\n  \"valid_until\": \"{{q_valid_until}}\"\n}" }
          }
        },
        {
          "name": "Add Line Item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/quotations/{{quotation_id}}/items/", "host": ["{{base_url}}"], "path": ["api", "v1", "quotations", "{{quotation_id}}", "items", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"product_description\": \"Centrifugal Pump 5HP\",\n  \"quantity\": \"10\",\n  \"unit\": \"nos\",\n  \"unit_cost\": \"8000\",\n  \"unit_price\": \"10000\",\n  \"discount_percent\": \"0\",\n  \"tax_rule\": {{tax_rule_id}}\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
